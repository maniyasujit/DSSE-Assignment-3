    "fields": {
      "summary": "ClientRMProtocol needs to allow the specification of a ResourceRequest so that the Application Master's Container can be placed on the specified host",
      "issuetype": {
        "self": "https://issues.apache.org/jira/rest/api/2/issuetype/4",
        "id": "4",
        "description": "An improvement or enhancement to an existing feature or task.",
