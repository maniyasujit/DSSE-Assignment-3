    "fields": {
      "summary": "YARN large file broadcast service",
      "issuetype": {
        "self": "https://issues.apache.org/jira/rest/api/2/issuetype/2",
        "id": "2",
        "description": "A new feature of the product, which has yet to be developed.",
        "iconUrl": "https://issues.apache.org/jira/secure/viewavatar?size=xsmall&avatarId=21141&avatarType=issuetype",
        "name": "New Feature",
        "subtask": false,
        "avatarId": 21141
      },
      "components": [],
      "subtasks": [],
      "created": "2016-07-18T15:49:10.775+0000",
      "description": "In Hadoop and related softwares, there are demands of broadcasting large files. For example, YARN application may localize large jar files on each node; Hive may distribute large tables in fragment-replicate joins; docker integration may broadcast large container image. The current local resource based solution is to put the files on HDFS and let each node download from HDFS, which is inefficient and not scalable. So we want to build a better file transfer service in YARN so that all applications can use it broadcast large file efficiently.",
      "priority": {
        "self": "https://issues.apache.org/jira/rest/api/2/priority/3",
        "iconUrl": "https://issues.apache.org/jira/images/icons/priorities/major.svg",
