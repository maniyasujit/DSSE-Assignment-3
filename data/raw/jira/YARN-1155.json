                "32x32": "https://issues.apache.org/jira/secure/useravatar?size=medium&avatarId=10443"
              },
              "displayName": "Xuan Gong",
              "active": true,
              "timeZone": "America/Los_Angeles"
            },
            "created": "2013-09-06T21:10:06.485+0000",
            "updated": "2013-09-06T21:10:06.485+0000"
          },
          {
            "self": "https://issues.apache.org/jira/rest/api/2/issue/12667222/comment/13760632",
