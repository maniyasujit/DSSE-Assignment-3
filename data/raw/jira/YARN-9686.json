    "fields": {
      "summary": "Reduce visibility of blacklisted nodes information (only for current app attempt) to avoid the abuse of memory",
      "issuetype": {
        "self": "https://issues.apache.org/jira/rest/api/2/issuetype/1",
        "id": "1",
        "description": "A problem which impairs or prevents the functions of the product.",
