      "issuelinks": [],
      "comment": {
        "comments": [
          {
            "self": "https://issues.apache.org/jira/rest/api/2/issue/13094835/comment/16127774",
            "id": "16127774",
            "author": {
              "self": "https://issues.apache.org/jira/rest/api/2/user?username=epayne",
              "name": "epayne",
              "key": "eepayne",
              "avatarUrls": {
                "48x48": "https://issues.apache.org/jira/secure/useravatar?ownerId=eepayne&avatarId=40831",
                "24x24": "https://issues.apache.org/jira/secure/useravatar?size=small&ownerId=eepayne&avatarId=40831",
                "16x16": "https://issues.apache.org/jira/secure/useravatar?size=xsmall&ownerId=eepayne&avatarId=40831",
                "32x32": "https://issues.apache.org/jira/secure/useravatar?size=medium&ownerId=eepayne&avatarId=40831"
              },
              "displayName": "Eric Payne",
              "active": true,
              "timeZone": "Etc/UTC"
            },
            "body": "Thanks [~saruntek] for raising this issue.\n\n{quote}\nAs of today the only way to enable preemption at a queue level is:\n- Enable cluster level preemption\n- Disable preemption on the queues where not required using yarn.scheduler.capacity.<queue-path>.disable_preemption to true\n\n{quote}\nActually, you don't need to {{disable_preemption}} for every queue. The {{disable_preemption}} property is inherited, so you can:\n- Enable cluster level preemption\n- Disable preemption on the root queue using {{yarn.scheduler.capacity.root.disable_preemption = true}}\n- Enable preemption on the queues where required using {{yarn.scheduler.capacity.<queue-path>.disable_preemption = false}}",
            "updateAuthor": {
              "self": "https://issues.apache.org/jira/rest/api/2/user?username=epayne",
              "name": "epayne",
              "key": "eepayne",
