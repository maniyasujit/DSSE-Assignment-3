          {
            "self": "https://issues.apache.org/jira/rest/api/2/issue/12650173/comment/13674035",
            "id": "13674035",
            "author": {
              "self": "https://issues.apache.org/jira/rest/api/2/user?username=kyleckie",
              "name": "kyleckie",
              "key": "kyleckie",
              "avatarUrls": {
                "48x48": "https://issues.apache.org/jira/secure/useravatar?avatarId=10452",
