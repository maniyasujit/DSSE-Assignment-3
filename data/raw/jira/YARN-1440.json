      {
        "self": "https://issues.apache.org/jira/rest/api/2/issue/12680807/comment/13831847",
        "id": "13831847",
        "author": {
          "self": "https://issues.apache.org/jira/rest/api/2/user?username=ledion",
          "name": "ledion",
          "key": "ledion",
          "avatarUrls": {
            "48x48": "https://issues.apache.org/jira/secure/useravatar?avatarId=10452",
            "24x24": "https://issues.apache.org/jira/secure/useravatar?size=small&avatarId=10452",
