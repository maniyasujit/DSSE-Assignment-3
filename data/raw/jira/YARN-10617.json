          {
            "self": "https://issues.apache.org/jira/rest/api/2/issue/13357482/comment/17281513",
            "id": "17281513",
            "author": {
              "self": "https://issues.apache.org/jira/rest/api/2/user?username=ananyo_rao",
              "name": "ananyo_rao",
              "key": "ananyo_rao",
              "avatarUrls": {
                "48x48": "https://issues.apache.org/jira/secure/useravatar?avatarId=34055",
                "24x24": "https://issues.apache.org/jira/secure/useravatar?size=small&avatarId=34055",
                "16x16": "https://issues.apache.org/jira/secure/useravatar?size=xsmall&avatarId=34055",
                "32x32": "https://issues.apache.org/jira/secure/useravatar?size=medium&avatarId=34055"
              },
              "displayName": "VADAGA ANANYO RAO",
              "active": true,
              "timeZone": "Asia/Kolkata"
            },
            "body": "Hi [~leftnoteasy] [~sunilg] , could you please review this jira? The fix is in proportional capacity preemption logic.\r\n\r\nBasically, instead of considering all apps for preemption, we only consider apps which are schedulable by the scheduling logic we are using.\r\n\r\ncc: [~epayne]\r\n\r\nThanks.",
            "updateAuthor": {
              "self": "https://issues.apache.org/jira/rest/api/2/user?username=ananyo_rao",
              "name": "ananyo_rao",
              "key": "ananyo_rao",
              "avatarUrls": {
                "48x48": "https://issues.apache.org/jira/secure/useravatar?avatarId=34055",
                "24x24": "https://issues.apache.org/jira/secure/useravatar?size=small&avatarId=34055",
                "16x16": "https://issues.apache.org/jira/secure/useravatar?size=xsmall&avatarId=34055",
                "32x32": "https://issues.apache.org/jira/secure/useravatar?size=medium&avatarId=34055"
              },
              "displayName": "VADAGA ANANYO RAO",
              "active": true,
              "timeZone": "Asia/Kolkata"
            },
            "created": "2021-02-09T04:21:02.074+0000",
            "updated": "2021-02-09T04:21:02.074+0000"
