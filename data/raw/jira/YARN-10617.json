    "key": "YARN-10617",
    "fields": {
      "summary": "Fifo and Fair intra-queue preemption goes on indefinitely when apps are in pending state due to max AM limit reached",
      "issuetype": {
        "self": "https://issues.apache.org/jira/rest/api/2/issuetype/4",
        "id": "4",
        "description": "An improvement or enhancement to an existing feature or task.",
        "iconUrl": "https://issues.apache.org/jira/secure/viewavatar?size=xsmall&avatarId=21140&avatarType=issuetype",
        "name": "Improvement",
        "subtask": false,
        "avatarId": 21140
      },
      "components": [
        {
          "self": "https://issues.apache.org/jira/rest/api/2/component/12327621",
          "id": "12327621",
          "name": "capacity scheduler"
        }
      ],
      "subtasks": [],
      "created": "2021-02-08T09:39:07.389+0000",
      "description": "This case occurs when:\r\n1. an application gets submitted in a cluster running at max-AM limit.\r\n2. The new job requests AM resource. So it has 1 pending request.\r\n3. To fulfil this request, the preemption logic preempts 1 resource from a running app.\r\n4. Because the cluster is at max-AM limit, the scheduler re-assigns the preempted container back to the running app.",
      "priority": {
        "self": "https://issues.apache.org/jira/rest/api/2/priority/3",
        "iconUrl": "https://issues.apache.org/jira/images/icons/priorities/major.svg",
        "name": "Major",
        "id": "3"
      },
      "resolution": null,
      "labels": [],
