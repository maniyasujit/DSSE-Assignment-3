                "24x24": "https://issues.apache.org/jira/secure/useravatar?size=small&avatarId=10452",
                "16x16": "https://issues.apache.org/jira/secure/useravatar?size=xsmall&avatarId=10452",
                "32x32": "https://issues.apache.org/jira/secure/useravatar?size=medium&avatarId=10452"
              },
              "displayName": "Li Lu",
              "active": true,
              "timeZone": "America/Los_Angeles"
            },
            "created": "2015-05-11T18:17:19.755+0000",
            "updated": "2015-05-11T18:17:19.755+0000"
          },
          {
            "self": "https://issues.apache.org/jira/rest/api/2/issue/12828132/comment/14637285",
            "id": "14637285",
            "author": {
              "self": "https://issues.apache.org/jira/rest/api/2/user?username=gtcarrera9",
              "name": "gtcarrera9",
              "key": "gtcarrera9",
              "avatarUrls": {
                "48x48": "https://issues.apache.org/jira/secure/useravatar?avatarId=10452",
                "24x24": "https://issues.apache.org/jira/secure/useravatar?size=small&avatarId=10452",
                "16x16": "https://issues.apache.org/jira/secure/useravatar?size=xsmall&avatarId=10452",
                "32x32": "https://issues.apache.org/jira/secure/useravatar?size=medium&avatarId=10452"
              },
              "displayName": "Li Lu",
              "active": true,
              "timeZone": "America/Los_Angeles"
            },
            "body": "Since we're moving phoenix storage to aggregation side, we need to fix this after we have a full story of the offline (time-based) aggregation. ",
