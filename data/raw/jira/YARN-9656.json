          "name": "wangda",
          "key": "wangda",
          "avatarUrls": {
            "48x48": "https://issues.apache.org/jira/secure/useravatar?ownerId=wangda&avatarId=16956",
            "24x24": "https://issues.apache.org/jira/secure/useravatar?size=small&ownerId=wangda&avatarId=16956",
