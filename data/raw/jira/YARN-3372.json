        "comments": [
          {
            "self": "https://issues.apache.org/jira/rest/api/2/issue/12783103/comment/14369361",
            "id": "14369361",
            "author": {
              "self": "https://issues.apache.org/jira/rest/api/2/user?username=stevel%40apache.org",
