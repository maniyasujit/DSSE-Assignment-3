          "active": true,
          "timeZone": "America/Los_Angeles"
        },
        "body": "[~rkanter]\u00a0 I have one question about setting the lifetime of the child certificate to 7 days. Is there any pitfall if we don't set a maximum lifetime?",
        "updateAuthor": {
          "self": "https://issues.apache.org/jira/rest/api/2/user?username=haibochen",
          "name": "haibochen",
          "key": "haibochen",
          "avatarUrls": {
