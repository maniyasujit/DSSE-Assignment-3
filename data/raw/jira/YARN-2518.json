            "32x32": "https://issues.apache.org/jira/secure/useravatar?size=medium&avatarId=10452"
          },
          "displayName": "BoYang",
          "active": true,
          "timeZone": "America/Los_Angeles"
        },
        "body": "We tried to use a custom Container Executor implementation, and hook it up with YARN. It seems working. But it would be still nice if YARN can provide native support for in-process container executor.",
        "updateAuthor": {
          "self": "https://issues.apache.org/jira/rest/api/2/user?username=bobyangbo",
          "name": "bobyangbo",
          "key": "bobyangbo",
          "avatarUrls": {
