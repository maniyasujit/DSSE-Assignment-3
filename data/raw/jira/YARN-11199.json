    "fields": {
      "summary": "Replace htrace-core with hbase-noop-htrace for CVE-2018-7489, CVE-2020-35491, CVE-2020-35490, and CVE-2020-36518 ",
      "issuetype": {
        "self": "https://issues.apache.org/jira/rest/api/2/issuetype/4",
        "id": "4",
        "description": "An improvement or enhancement to an existing feature or task.",
