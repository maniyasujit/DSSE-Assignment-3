                "32x32": "https://issues.apache.org/jira/secure/useravatar?size=medium&avatarId=10452"
              },
              "displayName": "Jason Darrell Lowe",
              "active": true,
              "timeZone": "America/Chicago"
            },
            "created": "2013-10-31T13:11:19.523+0000",
