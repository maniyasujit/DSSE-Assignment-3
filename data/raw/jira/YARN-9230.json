              },
              "displayName": "Eric Yang",
              "active": true,
              "timeZone": "America/Los_Angeles"
            },
            "body": "The rebased driver can be found at: https://github.com/eyanghwx/distribution/commit/08491b13c74305c159e1801dc26c6105447a9dc8\r\n\r\nThis is a docker registry code change.  There is nothing to be done in YARN to improve the user experience.  Hence, I am inclined to close this as no plan to fix.",
            "updateAuthor": {
              "self": "https://issues.apache.org/jira/rest/api/2/user?username=eyang",
              "name": "eyang",
              "key": "eyang",
              "avatarUrls": {
