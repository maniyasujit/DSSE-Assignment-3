            },
            "body": "[~ChrisKarampeazis]\r\n\r\nI agree with [~ebadger]\u00a0that we'd better split the list based on the file size.\u00a0 But how we can handle the dir size is 0?",
            "updateAuthor": {
              "self": "https://issues.apache.org/jira/rest/api/2/user?username=zhuqi",
              "name": "zhuqi",
              "key": "zhuqi",
              "avatarUrls": {
                "48x48": "https://issues.apache.org/jira/secure/useravatar?ownerId=zhuqi&avatarId=39200",
                "24x24": "https://issues.apache.org/jira/secure/useravatar?size=small&ownerId=zhuqi&avatarId=39200",
